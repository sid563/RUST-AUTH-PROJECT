HOST=127.0.0.1
PORT=8080
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db>?retryWrites=true&w=majority
MONGO_DB_NAME=task_auth_db
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace-with-a-long-random-secret
# Max requests per identity (logged-in user, else client IP) per 1-second bucket.
# Set to 0 to disable rate limiting.
RATE_LIMIT_PER_SECOND=60
